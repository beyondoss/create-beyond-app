{
  "name": "create-beyond-app",
  "version": "0.1.2",
  "description": "Scaffold a primitive-aware full-stack Beyond app — TanStack Start + Drizzle, wired to Beyond Postgres, Auth, KV, Queue, and Objects.",
  "type": "module",
  "bin": {
    "create-beyond-app": "bin/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beyondoss/create-beyond-app.git"
  },
  "homepage": "https://github.com/beyondoss/create-beyond-app#readme",
  "bugs": "https://github.com/beyondoss/create-beyond-app/issues",
  "files": [
    "bin/index.js",
    "template"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "shot": "node e2e/shot.mjs",
    "e2e": "docker compose -f harness/docker-compose.yml up -d --wait && node e2e/prepare-app.mjs && playwright test -c e2e/playwright.config.ts",
    "e2e:up": "docker compose -f harness/docker-compose.yml up -d --wait",
    "e2e:down": "docker compose -f harness/docker-compose.yml down -v",
    "e2e:report": "playwright show-report"
  },
  "keywords": [
    "beyond",
    "create-beyond-app",
    "tanstack-start",
    "drizzle",
    "full-stack",
    "starter"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
